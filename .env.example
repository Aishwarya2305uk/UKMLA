# ── UKMLA lead pipeline (api/submit-lead) ─────────────────────────────
# Copy to Vercel Project → Settings → Environment Variables.
# The pipeline is DORMANT until RESEND_API_KEY is set: the form still
# works and returns success, it just won't send email yet.

# Email delivery (Resend) — https://resend.com
RESEND_API_KEY=            # e.g. re_xxxxxxxxxxxxxxxx  (leave blank = dormant)
TEAM_INBOX=leads-test@trulaoverseas.com   # single recipient for testing
MAIL_FROM=UKMLA Leads <onboarding@resend.dev>   # verify your own domain for production

# IP intelligence (ISP / hostname) — https://ipinfo.io  (optional; works without a token, rate-limited)
IPINFO_TOKEN=

# HubSpot (later version — stub is dormant until this is set)
HUBSPOT_ACCESS_TOKEN=      # e.g. pat-na1-xxxxxxxx
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
