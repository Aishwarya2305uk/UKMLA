# ── UKMLA lead pipeline (api/submit-lead) ─────────────────────────────
# Copy to Vercel Project → Settings → Environment Variables.
# The pipeline is DORMANT until SMTP_HOST + EMAIL_USER + EMAIL_PASS are set:
# the form still works and returns success, it just won't send email yet.
# Put REAL values in .env.local (gitignored) — never in this file.

# Email delivery (SMTP via Nodemailer)
SMTP_HOST=                 # e.g. smtp.gmail.com, smtp.zoho.com, smtp.hostinger.com
SMTP_PORT=587              # 465 = SSL, 587 = STARTTLS (default 587)
SMTP_SECURE=               # optional: "true" for port 465, "false" for 587 (auto if blank)
EMAIL_USER=                # SMTP username / mailbox, e.g. you@yourdomain.com
EMAIL_PASS=                # SMTP password (or app password)
MAIL_FROM=                 # optional From header, defaults to "UKMLA Website <EMAIL_USER>"
TEAM_INBOX=                # where notifications land (defaults to EMAIL_USER)

# IP intelligence (ISP / hostname) — https://ipinfo.io  (optional; works without a token, rate-limited)
IPINFO_TOKEN=

# HubSpot (later version — stub is dormant until this is set)
HUBSPOT_ACCESS_TOKEN=      # e.g. pat-na1-xxxxxxxx
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=
